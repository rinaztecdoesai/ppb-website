# ─────────────────────────────────────────────────────────────────────────────
# Kereeb Content API — Prime Property Buyers blog generator
# ─────────────────────────────────────────────────────────────────────────────
# The blog is generated at BUILD TIME (see lp/shared/blog-build.py): the key is
# read here on the machine that runs the generator and is NEVER shipped to the
# browser or committed. Copy this file to .env.local and fill in THIS client's
# own Kereeb credentials. .env.local is gitignored.
#
#   cp .env.example .env.local   &&   edit .env.local
#
# Do NOT reuse another site's key — each Kereeb brand/site has its own.

# Base URL of the Kereeb Content API, no trailing slash.
# Example: https://app.kereeb.com
KEREEB_API_URL=

# Server-side API key for PPB's Kereeb site (starts with "kereeb_live_...").
# Sent as the `x-kereeb-key` request header. Build-time only.
KEREEB_API_KEY=
